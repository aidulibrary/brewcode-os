  "steps": [
    { "order": 1, "action": "prepare", "description": "确认法压壶洁净无异味。用热水预热玻璃壶身，倒掉预热用水。" },
    { "order": 2, "action": "dose", "description": "将 20g 浅烘古吉日晒咖啡粉倒入法压壶。中粗研磨控制细粉量。" },
    {
      "order": 3,
      "action": "pour",
      "description": "一次性注入 320ml 热水，93°C，确保所有咖啡粉被浸润。浅烘豆需要高温萃取。",
      "duration": { "value": 10, "unit": "s" },
      "waterAmount": { "value": 320, "unit": "ml" },
      "cumulativeWater": { "value": 320, "unit": "ml" },
      "pourStyle": "中心注水",
      "pourIntensity": "大水流"
    },
    {
      "order": 4,
      "action": "wait",
      "description": "盖上壶盖但不压下滤网，浸泡 8 分钟。浅烘豆密度高，需要更长时间释放风味。",
      "duration": { "value": 480, "unit": "s" }
    },
    {
      "order": 5,
      "action": "stir",
      "description": "用勺子轻轻打破表面浮壳，搅拌使咖啡粉沉降。",
      "duration": { "value": 5, "unit": "s" }
    },
    {
      "order": 6,
      "action": "wait",
      "description": "用勺子撇去表面浮沫和细粉。静置 5 分钟，让所有细粉沉降到底部。",
      "duration": { "value": 300, "unit": "s" }
    },
    {
      "order": 7,
      "action": "prepare",
      "description": "将滤网轻轻压至液面下方，缓慢倒出咖啡液。不要让滤网压到底部，避免搅动沉淀的细粉。",
      "duration": { "value": 15, "unit": "s" }
    },
    {
      "order": 8,
      "action": "taste",
      "description": "倒入杯中品鉴。预期风味：草莓和蓝莓的浆果爆炸感、百香果般的热带果香、花香扑鼻。法压壶的金属滤网保留了全部油脂，让浅烘豆的风味维度被放大到极致。这个方案证明了法压壶不是深烘的专利。"
    }
