    {
      "order": 1,
      "action": "prepare",
      "description": "用热水充分润湿漂白滤纸，预热 V60 01 滤杯和分享壶。倒掉预热用水。Hoffmann 强调滤纸必须完全贴合杯壁。"
    },
    {
      "order": 2,
      "action": "dose",
      "description": "将 15g 瑰夏咖啡粉倒入滤杯，轻轻拍平。不必刻意追求完美平整，自然均匀即可。"
    },
    {
      "order": 3,
      "action": "bloom",
      "description": "注入 38ml 水，95°C，从中心向外慢速绕圈两圈。Hoffmann 的方法强调闷蒸要充分但不冗长。闷蒸 45 秒。",
      "duration": { "value": 45, "unit": "s" },
      "waterAmount": { "value": 38, "unit": "ml" },
      "cumulativeWater": { "value": 38, "unit": "ml" },
      "pourStyle": "中心绕圈",
      "pourIntensity": "细水流"
    },
    {
      "order": 4,
      "action": "pour",
      "description": "主注水阶段：一次性持续注水至 250ml，中水流绕圈。Hoffmann 的核心哲学——不要分段、不要间断，让水流持续上升。保持壶嘴高度稳定在粉床上方约 5cm。",
      "duration": { "value": 45, "unit": "s" },
      "waterAmount": { "value": 212, "unit": "ml" },
      "cumulativeWater": { "value": 250, "unit": "ml" },
      "targetWeight": { "value": 250, "unit": "g" },
      "pourStyle": "绕圈注水",
      "pourIntensity": "中水流"
    },
    {
      "order": 5,
      "action": "stir",
      "description": "用勺子轻轻沿杯壁刮一圈，帮助附着在杯壁上的咖啡粉回归粉床。这是 Hoffmann 的标志性手法。",
      "duration": { "value": 5, "unit": "s" }
    },
    {
      "order": 6,
      "action": "wait",
      "description": "等待滴滤完成。不要搅拌、不要二次注水，让水流自然完成萃取。",
      "duration": { "value": 90, "unit": "s" }
    },
    {
      "order": 7,
      "action": "taste",
      "description": "倒入杯中品鉴。预期风味：茉莉花香扑鼻、柑橘般明亮的酸质、蜂蜜般绵长的甜感、佛手柑的优雅。1:16.7 的高粉水比让瑰夏的细腻层次得到充分展开，每一口都有不同的风味感受。"
    }
