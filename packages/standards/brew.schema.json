{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brewcode.dev/schemas/brew.schema.json",
  "title": "BrewCode OS 冲煮方案",
  "description": "BrewCode OS .brew 冲煮方案 JSON Schema v0.1 —— 定义手冲咖啡及其他冲煮方式的标准化数据格式。",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "引用本 schema 的 URI，便于校验时自动识别。"
    },
    "meta": {
      "type": "object",
      "description": "方案元信息：标识、版本、作者等。",
      "required": ["name", "version", "brewCodeVersion"],
      "properties": {
        "name": {
          "type": "string",
          "description": "方案名称，例如「夏季八冲 · 埃塞俄比亚 日晒 古吉」。",
          "minLength": 1,
          "maxLength": 200
        },
        "version": {
          "type": "string",
          "description": "方案自身版本号，遵循 SemVer，例如 1.0.0。",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
        },
        "brewCodeVersion": {
          "type": "string",
          "description": "BrewCode OS 规范版本号，例如 0.1。",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        },
        "author": {
          "type": "string",
          "description": "作者名称或 ID。"
        },
        "description": {
          "type": "string",
          "description": "方案简介/风味描述。",
          "maxLength": 2000
        },
        "license": {
          "type": "string",
          "description": "许可证标识（SPDX），例如 MIT、CC-BY-4.0。"
        },
        "tags": {
          "type": "array",
          "description": "标签列表，用于搜索和归类。",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "创建时间（ISO 8601）。"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "最后更新时间（ISO 8601）。"
        },
        "brewId": {
          "type": "string",
          "description": "方案唯一编号，格式 BC-YYYY-NNNN"
        },
        "source": {
          "type": "string",
          "description": "方案来源标注，如'基于XXX的方案修改'"
        }
      },
      "additionalProperties": false
    },
    "coffee": {
      "type": "object",
      "description": "咖啡豆信息。",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "咖啡豆名称，例如「埃塞俄比亚 古吉 日晒」。",
          "minLength": 1,
          "maxLength": 200
        },
        "producer": {
          "type": "string",
          "description": "生产者/庄园名称。"
        },
        "origin": {
          "type": "object",
          "description": "产地信息。",
          "properties": {
            "country": {
              "type": "string",
              "description": "国家，ISO 3166-1 alpha-2 或中文名称。"
            },
            "region": {
              "type": "string",
              "description": "产区，例如「古吉」「耶加雪菲」「蕙兰」。"
            },
            "farm": {
              "type": "string",
              "description": "庄园/处理站名称。"
            },
            "altitude": {
              "type": "string",
              "description": "海拔，例如「1900-2200m」。"
            }
          },
          "additionalProperties": false
        },
        "variety": {
          "type": "string",
          "description": "豆种，例如「Heirloom」「Bourbon」「Geisha」。"
        },
        "process": {
          "type": "string",
          "description": "处理法，例如「日晒」「水洗」「蜜处理」「厌氧发酵」。"
        },
        "roastLevel": {
          "type": "string",
          "description": "烘焙度，例如「浅烘」「中浅烘」「中烘」「中深烘」「深烘」。",
          "enum": ["极浅烘", "浅烘", "中浅烘", "中烘", "中深烘", "深烘", "极深烘"]
        },
        "roastDate": {
          "type": "string",
          "format": "date",
          "description": "烘焙日期（ISO 8601）。"
        },
        "roaster": {
          "type": "string",
          "description": "烘焙商名称。"
        },
        "flavorNotes": {
          "type": "array",
          "description": "官方风味描述。",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "equipment": {
      "type": "object",
      "description": "冲煮器具信息。",
      "properties": {
        "brewer": {
          "type": "string",
          "description": "冲煮器具类型，例如「V60」「Kalita Wave」「Origami」「Chemex」「法压壶」「爱乐压」。"
        },
        "brewerMaterial": {
          "type": "string",
          "description": "滤杯材质，例如「陶瓷」「树脂」「玻璃」「金属」。"
        },
        "brewerSize": {
          "type": "string",
          "description": "滤杯规格，例如「01」「02」。"
        },
        "filter": {
          "type": "string",
          "description": "滤纸类型，例如「V60 漂白」「V60 原色」「Kalita 波浪」。"
        },
        "grinder": {
          "type": "string",
          "description": "磨豆机型号，例如「C40」「Kinu M47」「EK43」。"
        },
        "kettle": {
          "type": "string",
          "description": "手冲壶型号。"
        },
        "scale": {
          "type": "string",
          "description": "电子秤型号。"
        },
        "server": {
          "type": "string",
          "description": "分享壶/下壶。"
        }
      },
      "additionalProperties": false
    },
    "recipe": {
      "type": "object",
      "description": "冲煮配方核心参数。",
      "required": ["dose", "waterAmount", "ratio", "grindSize", "waterTemperature"],
      "properties": {
        "dose": {
          "type": "object",
          "description": "咖啡粉用量。",
          "required": ["value", "unit"],
          "properties": {
            "value": {
              "type": "number",
              "description": "数值。",
              "minimum": 0,
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "description": "单位。",
              "enum": ["g"]
            }
          },
          "additionalProperties": false
        },
        "waterAmount": {
          "type": "object",
          "description": "总注水量。",
          "required": ["value", "unit"],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0,
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["ml", "g"]
            }
          },
          "additionalProperties": false
        },
        "ratio": {
          "type": "string",
          "description": "粉水比，例如「1:15」「1:16.7」。",
          "pattern": "^1:\\d+(\\.\\d+)?$",
          "examples": ["1:15", "1:16.7"]
        },
        "grindSize": {
          "type": "object",
          "description": "研磨度。",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "number",
              "description": "研磨刻度数值。",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "description": "刻度单位/参考系，例如「C40 click」「EK43 刻度」「μm」。",
              "examples": ["C40 click", "μm"]
            },
            "description": {
              "type": "string",
              "description": "研磨度口头描述，例如「细砂糖粗细」「比手冲略细」。"
            }
          },
          "additionalProperties": false
        },
        "waterTemperature": {
          "type": "object",
          "description": "水温。",
          "required": ["value", "unit"],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0,
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["°C", "°F"]
            }
          },
          "additionalProperties": false
        },
        "waterType": {
          "type": "string",
          "description": "用水类型，例如「农夫山泉」「调配水」「过滤水」。"
        },
        "waterTDS": {
          "type": "number",
          "description": "水 TDS 值（ppm）。",
          "minimum": 0
        },
        "brewTime": {
          "type": "object",
          "description": "目标总冲煮时间。",
          "properties": {
            "value": {
              "type": "number",
              "description": "时间数值。",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["s", "min"],
              "description": "时间单位。"
            }
          },
          "additionalProperties": false
        },
        "bloomRatio": {
          "type": "string",
          "description": "闷蒸水量比例，例如「1:2」「1:3」。",
          "pattern": "^1:\\d+(\\.\\d+)?$"
        },
        "bloomTime": {
          "type": "object",
          "description": "闷蒸时间。",
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["s", "min"]
            }
          },
          "additionalProperties": false
        },
        "targetTDS": {
          "type": "number",
          "description": "目标咖啡液 TDS（%）。",
          "minimum": 0
        },
        "targetExtraction": {
          "type": "number",
          "description": "目标萃取率（%）。",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "description": "冲煮步骤列表，按顺序执行。",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "action"],
        "properties": {
          "order": {
            "type": "integer",
            "description": "步骤序号，从 1 开始。",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "description": "操作类型。",
            "enum": [
              "prepare",
              "rinse",
              "grind",
              "dose",
              "bloom",
              "pour",
              "stir",
              "swirl",
              "drawdown",
              "wait",
              "measure",
              "taste",
              "note"
            ]
          },
          "description": {
            "type": "string",
            "description": "步骤详细说明。",
            "maxLength": 500
          },
          "duration": {
            "type": "object",
            "description": "步骤预计耗时。",
            "properties": {
              "value": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["s", "min"]
              }
            },
            "additionalProperties": false
          },
          "waterAmount": {
            "type": "object",
            "description": "本步骤注水量。",
            "properties": {
              "value": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["ml", "g"]
              }
            },
            "additionalProperties": false
          },
          "cumulativeWater": {
            "type": "object",
            "description": "累计注水量（到本步骤结束）。",
            "properties": {
              "value": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["ml", "g"]
              }
            },
            "additionalProperties": false
          },
          "targetWeight": {
            "type": "object",
            "description": "目标重量（含咖啡液的电子秤读数）。",
            "properties": {
              "value": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["g"]
              }
            },
            "additionalProperties": false
          },
          "pourStyle": {
            "type": "string",
            "description": "注水手法，例如「中心注水」「绕圈注水」「定点注水」「搅拌注水」。"
          },
          "pourIntensity": {
            "type": "string",
            "description": "注水强度/流速，例如「细水流」「中水流」「大水流」。"
          },
          "temperature": {
            "type": "object",
            "description": "本步骤水温（若与总体不同）。",
            "properties": {
              "value": {
                "type": "number",
                "minimum": 0,
                "exclusiveMinimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["°C", "°F"]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "result": {
      "type": "object",
      "description": "冲煮结果记录（实际出杯数据与品鉴笔记）。",
      "properties": {
        "actualBrewTime": {
          "type": "object",
          "description": "实际总冲煮时间。",
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["s", "min"]
            }
          },
          "additionalProperties": false
        },
        "finalYield": {
          "type": "object",
          "description": "最终咖啡液重量。",
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "enum": ["g", "ml"]
            }
          },
          "additionalProperties": false
        },
        "measuredTDS": {
          "type": "number",
          "description": "实测 TDS（%），例如 1.35。",
          "minimum": 0
        },
        "extractionYield": {
          "type": "number",
          "description": "实测萃取率（%），例如 20.5。",
          "minimum": 0
        },
        "rating": {
          "type": "number",
          "description": "综合评分 (0-10)。",
          "minimum": 0,
          "maximum": 10
        },
        "aroma": {
          "type": "object",
          "description": "干香/湿香评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "flavor": {
          "type": "object",
          "description": "风味评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "aftertaste": {
          "type": "object",
          "description": "余韵评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "acidity": {
          "type": "object",
          "description": "酸质评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "body": {
          "type": "object",
          "description": "醇厚度/口感评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "balance": {
          "type": "object",
          "description": "平衡感评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "sweetness": {
          "type": "object",
          "description": "甜感评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "cleanCup": {
          "type": "object",
          "description": "干净度评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        },
        "overall": {
          "type": "object",
          "description": "总体评价。",
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "notes": {
              "type": "string",
              "maxLength": 1000
            }
          },
          "additionalProperties": false
        },
        "tastingNotes": {
          "type": "array",
          "description": "品鉴风味笔记。",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "improvements": {
          "type": "string",
          "description": "下次改进建议。",
          "maxLength": 2000
        },
        "photoUrls": {
          "type": "array",
          "description": "出品照片 URL 列表。",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["meta", "coffee", "recipe", "steps"],
  "additionalProperties": false
}
